{
  "name": "kutlass-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "nx run-many -t build",
    "dev": "nx run kutlass-demo:dev",
    "lint": "nx run-many -t lint",
    "test": "nx run kutlass:test",
    "build:lib": "nx run kutlass:build",
    "build:app": "nx run kutlass-demo:build"
  },
  "dependencies": {
    "@ffmpeg/core": "^0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "framer-motion": "^12.40.0",
    "kutlass": "^0.1.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "nx": "^23.0.0"
  }
}
